@prefix aq: <http://aqi-prediction.org/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aq:Feature_CO a aq:EnvironmentalFeature ;
    aq:affectedGroup "People with heart disease" ;
    aq:hasHealthRisk "Reduces oxygen delivery to body's organs" ;
    aq:hasLikelySource "Incomplete combustion" ;
    aq:mitigationAdvice "Ensure proper ventilation indoors, check car exhaust" .

aq:Pred_Current_Observation a aq:Prediction ;
    aq:hasFeatureInput aq:Feature_NO2,
        aq:Feature_Ozone,
        aq:Feature_PM10,
        aq:Feature_PM2.5,
        aq:Feature_temperature,
        aq:Feature_windspeed ;
    aq:hasPredictedValue "126.7"^^xsd:float ;
    aq:regulatoryStatus "Violates WHO PM2.5 Guideline (Limit: 15, Observed: 37.43)" .

aq:Feature_NO2 a aq:EnvironmentalFeature ;
    aq:affectedGroup "Children with asthma" ;
    aq:hasHealthRisk "Inflammation of airways, reduced lung function" ;
    aq:hasLikelySource "Burning of fossil fuels (cars)" ;
    aq:hasObservedValue "11.46"^^xsd:float ;
    aq:mitigationAdvice "Avoid traffic-heavy routes, carpool, use electric vehicles" .

aq:Feature_Ozone a aq:EnvironmentalFeature ;
    aq:affectedGroup "Outdoor workers, active children" ;
    aq:hasHealthRisk "Chest pain, throat irritation" ;
    aq:hasLikelySource "Chemical reaction in sunlight" ;
    aq:hasObservedValue "63.58"^^xsd:float ;
    aq:mitigationAdvice "Refuel cars in the evening, limit daytime driving" .

aq:Feature_PM10 a aq:EnvironmentalFeature ;
    aq:affectedGroup "Construction workers, people with bronchitis" ;
    aq:hasHealthRisk "Lung irritation, coughing" ;
    aq:hasLikelySource "Dust storms, agriculture" ;
    aq:hasObservedValue "139.73"^^xsd:float ;
    aq:mitigationAdvice "Wet sweeping of roads, cover construction sites" .

aq:Feature_PM2.5 a aq:EnvironmentalFeature ;
    aq:affectedGroup "Children, Elderly, Asthmatics" ;
    aq:hasHealthRisk "Penetrates deep into lungs, asthma aggravation" ;
    aq:hasLikelySource "Vehicle exhaust, construction dust" ;
    aq:hasObservedValue "37.43"^^xsd:float ;
    aq:mitigationAdvice "Use air purifiers, wear N95 masks, restrict outdoor exercise" .

aq:Feature_temperature a aq:EnvironmentalFeature ;
    aq:affectedGroup "Elderly, Infants" ;
    aq:hasHealthRisk "High heat accelerates chemical reactions" ;
    aq:hasLikelySource "Meteorological condition" ;
    aq:hasObservedValue "0"^^xsd:float ;
    aq:mitigationAdvice "Stay hydrated, avoid peak sun hours" .

aq:Feature_windspeed aq:hasObservedValue "0"^^xsd:float .

